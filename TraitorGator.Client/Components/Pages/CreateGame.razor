@page "/create-game"
@using System.Text.Json
@using System.Text.Json.Serialization
@using TraitorGator.API.Models
@using TraitorGator.Shared.Dtos
@using TraitorGator.Models
@inject HttpClient Http
@inject NavigationManager NavManager
@rendermode InteractiveServer

<div class="d-flex vh-100 align-items-center justify-content-center">
    <div class="card bg-dark text-light p-4 shadow-sm" style="width: 100%; max-width: 400px;">
        <h2 class="display-7 text-center mb-3">Skapa nytt spel</h2>
        <div class="mb-3 text-start">
            <input id="username" class="form-control form-control-lg" @bind="createRequest.Username" placeholder="Ditt användarnamn" />
        </div>

        <button class="btn btn-primary btn-lg w-100 mb-3" @onclick="CreateGameTG">Skapa spel</button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger text-start">
                @errorMessage
            </div>
        }
    </div>
</div>

@code {
    private CreateGameRequest createRequest = new();
    private string errorMessage;

    private async Task CreateGameTG()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(createRequest.Username))
        {
            errorMessage = "Du måste ange ett användarnamn.";
            return;
        }

        // 1) Skapa spelet
        var createResponse = await Http.PostAsync("api/game/create", null);
        if (!createResponse.IsSuccessStatusCode)
        {
            errorMessage = "Fel vid skapande av spel.";
            return;
        }

        // 2) Läs in GameRound
        var game = await createResponse.Content.ReadFromJsonAsync<GameRound>(new JsonSerializerOptions
            {
                ReferenceHandler = ReferenceHandler.Preserve,
                PropertyNameCaseInsensitive = true
            });
        if (game == null)
        {
            errorMessage = "Kunde inte läsa in spelet.";
            return;
        }

        // 3) Gör join-anrop
        var joinRequest = new JoinGameRequest
            {
                GameCode = game.GameCode,
                Username = createRequest.Username
            };

        var joinResponse = await Http.PostAsJsonAsync("api/game/join", joinRequest);
        if (!joinResponse.IsSuccessStatusCode)
        {
            var err = await joinResponse.Content.ReadAsStringAsync();
            errorMessage = $"Fel vid join av spel: {joinResponse.StatusCode}\n{err}";
            return;
        }

        // 4) Navigera till lobby
        var player = await joinResponse.Content.ReadFromJsonAsync<Player>();
        NavManager.NavigateTo($"/lobby/{game.GameCode}/{player.Id}");
    }
}
