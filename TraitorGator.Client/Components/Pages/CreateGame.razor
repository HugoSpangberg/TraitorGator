@page "/create-game"
@using TraitorGator.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager NavManager
@rendermode InteractiveServer

<main class="screen screen--center">
    <section class="panel panel--narrow">
        <a class="back-link" href="/">Tillbaka</a>
        <h1>Skapa spel</h1>

        <label class="field">
            <span>Namn</span>
            <input @bind="createRequest.Username" @bind:event="oninput" maxlength="24" placeholder="Ditt användarnamn" />
        </label>

        <label class="field">
            <span>Rundor</span>
            <input type="number" min="1" max="5" @bind="createRequest.MaxRounds" />
        </label>

        <button class="button button--primary button--full" disabled="@isLoading" @onclick="CreateGameTG">
            @(isLoading ? "Skapar..." : "Skapa lobby")
        </button>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="alert alert--error">@errorMessage</p>
        }
    </section>
</main>

@code {
    private readonly CreateGameRequest createRequest = new() { MaxRounds = 3 };
    private string? errorMessage;
    private bool isLoading;

    private async Task CreateGameTG()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(createRequest.Username))
        {
            errorMessage = "Du måste ange ett användarnamn.";
            return;
        }

        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/game/create", createRequest);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await ReadErrorAsync(response, "Kunde inte skapa spelet.");
                return;
            }

            var session = await response.Content.ReadFromJsonAsync<PlayerSessionDto>();
            if (session == null)
            {
                errorMessage = "API:t returnerade inget spel.";
                return;
            }

            NavManager.NavigateTo($"/lobby/{session.GameCode}/{session.PlayerId}/{session.PlayerSecret}");
        }
        catch (HttpRequestException)
        {
            errorMessage = "API:t svarar inte. Kontrollera att TraitorGator.API körs.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static async Task<string> ReadErrorAsync(HttpResponseMessage response, string fallback)
    {
        var body = (await response.Content.ReadAsStringAsync()).Trim().Trim('"');
        return string.IsNullOrWhiteSpace(body) ? fallback : body;
    }
}
