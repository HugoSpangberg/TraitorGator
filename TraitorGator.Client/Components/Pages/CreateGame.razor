@page "/create-game"
@using TraitorGator.API.Controllers
@using TraitorGator.API.Models
@inject HttpClient Http
@inject NavigationManager NavManager

<h1>Skapa Spel</h1>

<EditForm Model="@createRequest" OnValidSubmit="CreateGameTG">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="mb-3">
        <label for="username" class="form-label">Användarnamn</label>
        <InputText id="username" class="form-control" @bind-Value="createRequest.Username" />
    </div>
    <button type="submit" class="btn btn-primary">Skapa spel</button>
</EditForm>

@code {
    // En DTO för att ta emot användarnamn – vi behöver inte skicka med något annat för att skapa spelet
    public class CreateGameRequest
    {
        public string Username { get; set; }
    }

    private CreateGameRequest createRequest = new CreateGameRequest();

    // När spelet skapas anropas både create och join endpoints
    private async Task CreateGameTG()
    {
        // Anropa create-spel-endpointen (som kanske inte behöver några data från klienten)
        var createResponse = await Http.PostAsync("api/game/create", null);
        if (createResponse.IsSuccessStatusCode)
        {
            // Läs in det skapade spelet (GameRound)
            var game = await createResponse.Content.ReadFromJsonAsync<GameRound>(new System.Text.Json.JsonSerializerOptions
                {
                    ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.Preserve,
                    PropertyNameCaseInsensitive = true
                });

            // Bygg ett join-request med gameCode och användarnamn
            var joinRequest = new JoinGameRequest
                {
                    GameCode = game.GameCode,
                    Username = createRequest.Username
                };

            // Anropa join-endpointen
            var joinResponse = await Http.PostAsJsonAsync("api/game/join", joinRequest);
            if (joinResponse.IsSuccessStatusCode)
            {
                // Navigera till spellobbyn med gameCode som parameter
                NavManager.NavigateTo($"/lobby/{game.GameCode}");
            }
            else
            {
                // Hantera fel
                Console.WriteLine("Fel vid join av spel");
            }
        }
        else
        {
            Console.WriteLine("Fel vid skapande av spel");
        }
    }
}
