@page "/play/{GameCode}/{PlayerId:guid}/{PlayerSecret}"
@rendermode InteractiveServer
@implements IDisposable

@using System.Threading
@using TraitorGator.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager NavManager

<main class="screen screen--center">
    <section class="panel panel--play">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Runda @currentRound</p>
                <h1>Svara diskret</h1>
            </div>
            <div class="timer">@remainingSeconds</div>
        </div>

        @if (question == null)
        {
            <p class="muted">Laddar fråga...</p>
        }
        else
        {
            <article class="question-card">
                <p>@question.Text</p>
            </article>

            @if (!answered)
            {
                <label class="field">
                    <span>Ditt svar</span>
                    <textarea @bind="answerText" @bind:event="oninput" maxlength="500" rows="5" placeholder="Skriv ett svar gruppen kan diskutera..."></textarea>
                </label>

                <button class="button button--primary button--full" disabled="@submitting" @onclick="() => SubmitAnswerAsync(false)">
                    @(submitting ? "Skickar..." : "Skicka svar")
                </button>
            }
            else
            {
                <div class="status-box">
                    <h2>Svar skickat</h2>
                    <p>Väntar på resten av gruppen. Resultatet öppnas automatiskt.</p>
                </div>
            }
        }

        @if (progress != null)
        {
            <p class="muted">@progress.AnswersSubmitted av @progress.PlayerCount svar inne.</p>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="alert alert--error">@errorMessage</p>
        }
    </section>
</main>

@code {
    [Parameter] public string GameCode { get; set; } = string.Empty;
    [Parameter] public Guid PlayerId { get; set; }
    [Parameter] public string PlayerSecret { get; set; } = string.Empty;

    private QuestionForPlayerDto? question;
    private RoundProgressDto? progress;
    private int currentRound = 1;
    private bool answered;
    private bool submitting;
    private int remainingSeconds;
    private string answerText = string.Empty;
    private string? errorMessage;
    private Timer? countdownTimer;
    private Timer? pollAnswersTimer;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var state = await Http.GetFromJsonAsync<GameStateDto>($"api/game/{GameCode}");
            answered = state?.Players.FirstOrDefault(p => p.Id == PlayerId)?.HasAnswered == true;

            question = await LoadQuestionAsync();
            currentRound = question?.RoundNumber ?? state?.CurrentRound ?? 1;
            remainingSeconds = question?.DurationSeconds ?? state?.DurationSeconds ?? 90;
            progress = await Http.GetFromJsonAsync<RoundProgressDto>($"api/gameplay/{GameCode}/progress?round={currentRound}");

            if (answered)
            {
                StartPollingAnswers();
            }
            else
            {
                StartCountdown();
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Kunde inte ladda rundan. Kontrollera att API:t körs.";
        }
    }

    private async Task<QuestionForPlayerDto?> LoadQuestionAsync()
    {
        using var request = new HttpRequestMessage(HttpMethod.Get, $"api/gameplay/{GameCode}/question?playerId={PlayerId}");
        request.Headers.Add("X-Player-Secret", PlayerSecret);
        using var response = await Http.SendAsync(request);
        if (!response.IsSuccessStatusCode)
        {
            errorMessage = await ReadErrorAsync(response, "Kunde inte hämta frågan.");
            return null;
        }

        return await response.Content.ReadFromJsonAsync<QuestionForPlayerDto>();
    }

    private void StartCountdown()
    {
        countdownTimer?.Dispose();
        countdownTimer = new Timer(_ => _ = InvokeAsync(TickCountdownAsync), null, 1000, 1000);
    }

    private async Task TickCountdownAsync()
    {
        if (answered)
        {
            countdownTimer?.Dispose();
            return;
        }

        remainingSeconds = Math.Max(remainingSeconds - 1, 0);
        if (remainingSeconds == 0)
        {
            countdownTimer?.Dispose();
            await SubmitAnswerAsync(autoSubmit: true);
        }

        StateHasChanged();
    }

    private async Task SubmitAnswerAsync(bool autoSubmit)
    {
        if (submitting || answered || question == null)
        {
            return;
        }

        var text = autoSubmit ? "(inget svar)" : answerText.Trim();
        if (string.IsNullOrWhiteSpace(text))
        {
            errorMessage = "Skriv ett svar innan du skickar.";
            return;
        }

        submitting = true;
        errorMessage = null;
        try
        {
            var payload = new SubmitAnswerRequest
            {
                PlayerId = PlayerId,
                PlayerSecret = PlayerSecret,
                QuestionId = question.QuestionId,
                AnswerText = text
            };

            var response = await Http.PostAsJsonAsync("api/answers/submit", payload);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await ReadErrorAsync(response, "Kunde inte skicka svaret.");
                return;
            }

            answered = true;
            countdownTimer?.Dispose();
            StartPollingAnswers();
        }
        finally
        {
            submitting = false;
        }
    }

    private void StartPollingAnswers()
    {
        if (pollAnswersTimer != null)
        {
            return;
        }

        pollAnswersTimer = new Timer(_ => _ = InvokeAsync(PollAnswersAsync), null, 0, 2000);
    }

    private async Task PollAnswersAsync()
    {
        progress = await Http.GetFromJsonAsync<RoundProgressDto>($"api/gameplay/{GameCode}/progress?round={currentRound}");
        if (progress?.AllAnswered == true)
        {
            pollAnswersTimer?.Dispose();
            pollAnswersTimer = null;
            NavManager.NavigateTo($"/results/{GameCode}/{PlayerId}/{PlayerSecret}/{currentRound}");
            return;
        }

        StateHasChanged();
    }

    private static async Task<string> ReadErrorAsync(HttpResponseMessage response, string fallback)
    {
        var body = (await response.Content.ReadAsStringAsync()).Trim().Trim('"');
        return string.IsNullOrWhiteSpace(body) ? fallback : body;
    }

    public void Dispose()
    {
        countdownTimer?.Dispose();
        pollAnswersTimer?.Dispose();
    }
}
