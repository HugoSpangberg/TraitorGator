@page "/play/{GameCode}/{PlayerId:guid}"
@rendermode InteractiveServer

@using TraitorGator.API.Models
@using TraitorGator.Models.Dto
@using TraitorGator.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="d-flex vh-100 align-items-center justify-content-center play-container">
    <div class="card bg-dark text-light p-4 shadow-sm" style="width: 100%; max-width: 500px;">

        <h2 class="card-title text-center mb-3">Runda @currentRound</h2>

        @if (question == null)
        {
            <p class="text-center">Laddar fråga…</p>
        }
        else if (!answered)
        {
            <div class="mb-3">
                <p class="fs-5">@question.Text</p>
            </div>

            <textarea @bind="answerText"
                      class="form-control bg-secondary bg-opacity-10 text-light mb-3"
                      rows="4"
                      placeholder="Skriv ditt svar här..."></textarea>

            <div class="d-flex justify-content-between align-items-center">
                <button class="btn btn-primary" @onclick="SubmitAnswer">
                    Skicka
                </button>
                <span class="timer-badge">@remainingSeconds s</span>
            </div>
        }
        else
        {
            <p class="text-center fst-italic">Tack! Vänta på övriga…</p>
        }

    </div>
</div>

@code {
    [Parameter] 
    public string GameCode { get; set; }
    [Parameter] 
    public Guid PlayerId { get; set; }

    private QuestionForPlayerDto question;
    private int currentRound;
    private bool answered;
    private int remainingSeconds;
    private string answerText;

    private Timer countdownTimer;
    private Timer pollAnswersTimer;

    protected override async Task OnInitializedAsync()
    {
        var round = await Http.GetFromJsonAsync<GameRound>($"api/game/{GameCode}");
        currentRound = round.CurrentRound;
        remainingSeconds = (int)round.Duration.TotalSeconds;

        question = await Http.GetFromJsonAsync<QuestionForPlayerDto>($"api/gameplay/{GameCode}/question?playerId={PlayerId}");

        countdownTimer = new Timer(_ =>
        {
            if (remainingSeconds > 0)
            {
                remainingSeconds--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                answered = true;
                InvokeAsync(StateHasChanged);
                countdownTimer.Dispose();
                StartPollingAnswers();
            }
        }, null, 1000, 1000);
    }

    private async Task SubmitAnswer()
    {
        if (string.IsNullOrWhiteSpace(answerText))
            return;

        var payload = new SubmitAnswerRequest
            {
                PlayerId = PlayerId,
                QuestionId = question.QuestionId,
                AnswerText = answerText
            };

        var res = await Http.PostAsJsonAsync("api/answers/submit", payload);
        if (res.IsSuccessStatusCode)
        {
            answered = true;
            countdownTimer?.Dispose();
            StartPollingAnswers();
        }
    }

    private void StartPollingAnswers()
    {
        pollAnswersTimer = new Timer(async _ =>
        {
            var answers = await Http.GetFromJsonAsync<IEnumerable<AnswerResultDto>>(
                $"api/gameplay/{GameCode}/answers");

            var round = await Http.GetFromJsonAsync<GameRound>($"api/game/{GameCode}");
            if (answers.Count() >= round.Players.Count)
            {
                pollAnswersTimer.Dispose();
                await InvokeAsync(() =>
                    NavManager.NavigateTo($"/results/{GameCode}/{currentRound}")
                );
            }
        }, null, 2000, 2000);
    }

    public void Dispose()
    {
        countdownTimer?.Dispose();
        pollAnswersTimer?.Dispose();
    }
}
