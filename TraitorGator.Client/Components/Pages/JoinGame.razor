@page "/join-game"
@rendermode InteractiveServer
@using TraitorGator.API.Models
@using TraitorGator.Shared.Dtos    @* Gemensamma DTO:er *@
@inject HttpClient Http
@inject NavigationManager NavManager

<h1>Gå med i spel</h1>

<div class="mb-3">
    <label for="gameCode" class="form-label">Game Code</label>
    <input id="gameCode"
           class="form-control"
           @bind="joinRequest.GameCode"
           placeholder="Ange game code" />
</div>

<div class="mb-3">
    <label for="username" class="form-label">Användarnamn</label>
    <input id="username"
           class="form-control"
           @bind="joinRequest.Username"
           placeholder="Ange användarnamn" />
</div>

<button class="btn btn-primary" @onclick="JoinGameTG">Gå med i spel</button>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-2">@errorMessage</div>
}

@code {
    private JoinGameRequest joinRequest = new();
    private string errorMessage;

    private async Task JoinGameTG()
    {
        errorMessage = null;

        // Grundläggande validering
        if (string.IsNullOrWhiteSpace(joinRequest.GameCode) ||
            string.IsNullOrWhiteSpace(joinRequest.Username))
        {
            errorMessage = "Båda fälten (game code och användarnamn) måste fyllas i.";
            return;
        }

        // Skicka join-anropet
        var response = await Http.PostAsJsonAsync("api/game/join", joinRequest);
        if (!response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Fel vid join: {response.StatusCode}\n{body}");
            errorMessage = "Kunde inte gå med i spelet. Kontrollera game code och försök igen.";
            return;
        }

        // Vid lyckat join: hämta Player och navigera
        var player = await response.Content.ReadFromJsonAsync<Player>();
        // joinRequest.GameCode finns fortfarande tillgänglig här
        NavManager.NavigateTo($"/lobby/{joinRequest.GameCode}/{player.Id}");
    }
}
