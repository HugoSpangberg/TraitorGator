@page "/join-game"
@rendermode InteractiveServer
@using TraitorGator.API.Models
@using TraitorGator.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="d-flex vh-100 align-items-center justify-content-center join-container">
    <div class="card bg-dark text-light p-4 shadow-sm" style="width: 100%; max-width: 450px;">
        <h2 class="display-10 text-center mb-4">Gå med i spel</h2>

        <div class="mb-3">
            <input id="gameCode"
                   class="form-control bg-opacity-10 text-light form-control-lg"
                   @bind="joinRequest.GameCode"
                   placeholder="Spelkod" />
        </div>

        <div class="mb-3">
            <input id="username"
                   class="form-control bg-opacity-10 text-light form-control-lg"
                   @bind="joinRequest.Username"
                   placeholder="Användarnamn" />
        </div>

        <button class="btn btn-primary w-100 mb-2" @onclick="JoinGameTG">
            Gå med i spel
        </button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-2 text-center">
                @errorMessage
            </div>
        }
    </div>
</div>

@code {
    private JoinGameRequest joinRequest = new();
    private string errorMessage;

    private async Task JoinGameTG()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(joinRequest.GameCode) ||
            string.IsNullOrWhiteSpace(joinRequest.Username))
        {
            errorMessage = "Båda fälten (Spelkod och användarnamn) måste fyllas i.";
            return;
        }

        var response = await Http.PostAsJsonAsync("api/game/join", joinRequest);
        if (!response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadAsStringAsync();
            errorMessage = "Kunde inte gå med i spelet. Kontrollera Spelkod och försök igen.";
            return;
        }

        var player = await response.Content.ReadFromJsonAsync<Player>();
        NavManager.NavigateTo($"/lobby/{joinRequest.GameCode}/{player.Id}");
    }
}
