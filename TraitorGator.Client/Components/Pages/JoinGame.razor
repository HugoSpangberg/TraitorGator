@page "/join-game"
@using TraitorGator.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager NavManager
@rendermode InteractiveServer

<main class="screen screen--center">
    <section class="panel panel--narrow">
        <a class="back-link" href="/">Tillbaka</a>
        <h1>Gå med</h1>

        <label class="field">
            <span>Spelkod</span>
            <input class="code-input" @bind="joinRequest.GameCode" @bind:event="oninput" maxlength="8" placeholder="0000" />
        </label>

        <label class="field">
            <span>Namn</span>
            <input @bind="joinRequest.Username" @bind:event="oninput" maxlength="24" placeholder="Ditt användarnamn" />
        </label>

        <button class="button button--primary button--full" disabled="@isLoading" @onclick="JoinGameTG">
            @(isLoading ? "Går med..." : "Gå med i lobby")
        </button>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="alert alert--error">@errorMessage</p>
        }
    </section>
</main>

@code {
    private readonly JoinGameRequest joinRequest = new();
    private string? errorMessage;
    private bool isLoading;

    private async Task JoinGameTG()
    {
        errorMessage = null;
        joinRequest.GameCode = joinRequest.GameCode.Trim().ToUpperInvariant();

        if (string.IsNullOrWhiteSpace(joinRequest.GameCode) || string.IsNullOrWhiteSpace(joinRequest.Username))
        {
            errorMessage = "Både spelkod och användarnamn måste fyllas i.";
            return;
        }

        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/game/join", joinRequest);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await ReadErrorAsync(response, "Kunde inte gå med i spelet.");
                return;
            }

            var session = await response.Content.ReadFromJsonAsync<PlayerSessionDto>();
            if (session == null)
            {
                errorMessage = "API:t returnerade ingen spelarsession.";
                return;
            }

            NavManager.NavigateTo($"/lobby/{session.GameCode}/{session.PlayerId}/{session.PlayerSecret}");
        }
        catch (HttpRequestException)
        {
            errorMessage = "API:t svarar inte. Kontrollera att TraitorGator.API körs.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static async Task<string> ReadErrorAsync(HttpResponseMessage response, string fallback)
    {
        var body = (await response.Content.ReadAsStringAsync()).Trim().Trim('"');
        return string.IsNullOrWhiteSpace(body) ? fallback : body;
    }
}
