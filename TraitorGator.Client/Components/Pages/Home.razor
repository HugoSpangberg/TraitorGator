@page "/"
@inject NavigationManager NavManager
@rendermode InteractiveServer
<PageTitle>TraitorGator</PageTitle>

<main class="screen screen--center">
    <section class="hero">
        <img class="brand-mark" src="/brand-mark.svg" alt="" />
        <p class="eyebrow">Social deduction</p>
        <h1>TraitorGator</h1>
        <p class="lead">
            Svara på nästan samma fråga, jämför svaren och rösta ut spelaren som försöker smälta in.
        </p>
        <div class="actions">
            <button class="button button--primary" @onclick="NavigateToCreateGame">Skapa spel</button>
            <button class="button button--secondary" @onclick="NavigateToJoinGame">Gå med</button>
        </div>
    </section>
</main>

@code {
    private void NavigateToCreateGame() => NavManager.NavigateTo("/create-game");

    private void NavigateToJoinGame() => NavManager.NavigateTo("/join-game");
}
