@page "/game"
@using TraitorGator.API.Controllers
@using TraitorGator.API.Models
@rendermode InteractiveServer
@inject IJSRuntime JsRuntime


<h1>Spela TraitorGator</h1>
<p>Skapa ett nytt spel eller gå med i ett befintligt spel.</p>

<div class="row">
    <div class="col-12 col-md-6">
        <h3>Skapa spel</h3>
        <button class="btn btn-primary" @onclick="CreateGameGamla">Skapa spel</button>
        @if (currentGame != null)
        {
            <div class="alert alert-success mt-2">
                Spel skapat! GameCode: <strong>@currentGame.GameCode</strong>
            </div>
        }
    </div>
    <div class="col-12 col-md-6">
        <h3>Gå med i spel</h3>
        <EditForm Model="@joinRequest" OnValidSubmit="JoinGame">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="mb-3">
                <label for="gameCode" class="form-label">Game Code</label>
                <InputText id="gameCode" class="form-control" @bind-Value="joinRequest.GameCode" />
            </div>
            <div class="mb-3">
                <label for="username" class="form-label">Användarnamn</label>
                <InputText id="username" class="form-control" @bind-Value="joinRequest.Username" />
            </div>
            <button type="submit" class="btn btn-primary">Gå med i spel</button>
        </EditForm>
        @if (joinedPlayer != null)
        {
            <div class="alert alert-success mt-2">
                Du har gått med i spelet! Ditt Player ID: <strong>@joinedPlayer.Id</strong>
            </div>
        }
    </div>
</div>

@code {
    // Modell för att ta emot svar från API:t
    private GameRound currentGame;
    private Player joinedPlayer;

    // DTO för att gå med i spel
    private JoinGameRequest joinRequest = new JoinGameRequest();
    
    // Metod för att skapa ett nytt spel
    private async Task CreateGameGamla()
    {
        try
        {
            var response = await Http.PostAsync("api/game/create", null);
            Console.WriteLine($"Response status: {response.StatusCode}");
            var jsonResponse = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Response JSON: {jsonResponse}");

            if (response.IsSuccessStatusCode)
            {
                var options = new System.Text.Json.JsonSerializerOptions
                    {
                        ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.Preserve,
                        PropertyNameCaseInsensitive = true
                    };

                currentGame = await response.Content.ReadFromJsonAsync<GameRound>(options);
                Console.WriteLine($"Game created with GameCode: {currentGame?.GameCode}");
                StateHasChanged();
            }
            else
            {
                Console.WriteLine("Fel vid skapande av spel");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
        }
    }

    // Metod för att gå med i ett spel
    private async Task JoinGame()
    {
        var response = await Http.PostAsJsonAsync("api/game/join", joinRequest);
        if (response.IsSuccessStatusCode)
        {
            var options = new System.Text.Json.JsonSerializerOptions
                {
                    ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.Preserve,
                    PropertyNameCaseInsensitive = true
                };
            joinedPlayer = await response.Content.ReadFromJsonAsync<Player>(options);
            StateHasChanged();
        }
    }
}
