@page "/lobby/{GameCode}/{PlayerId:guid}"
@rendermode InteractiveServer
@implements IAsyncDisposable

@using System.Threading
@using TraitorGator.API.Models
@inject HttpClient Http
@inject NavigationManager NavManager

<h1>Spellobby</h1>
<p>Game Code: <strong>@GameCode</strong></p>

@if (currentGame == null)
{
    <p>Laddar lobby …</p>
}
else
{
    <h3>Spelare i lobbyn:</h3>
    <ul class="list-group mb-3">
        @foreach (var p in currentGame.Players)
        {
            <li class="list-group-item">@p.Username (@p.Role)</li>
        }
    </ul>

    @if (!gameStarted)
    {
        @if (IsCreator)
        {
            <button class="btn btn-success" @onclick="OnStartGame">Starta spelet</button>
        }
        else
        {
            <p>Väntar på att skaparen startar spelet…</p>
        }
    }
}

@if (showRoleModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4 text-center">
                <h4>Din roll är:</h4>
                <p class="fs-2">@userRole</p>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string GameCode { get; set; }
    [Parameter] public Guid PlayerId { get; set; }

    private GameRound currentGame;
    private CancellationTokenSource _cts = new();
    private bool gameStarted = false;
    private bool showRoleModal = false;
    private string userRole;

    private bool IsCreator =>
        currentGame?.Players?.FirstOrDefault()?.Id == PlayerId;

    protected override async Task OnInitializedAsync()
    {
        await RefreshLobbyAsync();

        _ = PollLobbyAsync(_cts.Token);
    }

    private async Task PollLobbyAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(5), ct);
                await RefreshLobbyAsync();

                if (!gameStarted && currentGame?.Started == true)
                {
                    gameStarted = true;
                    await InvokeAsync(HandleGameStartAsync);
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Polling Error: {ex}");
        }
    }

    private async Task RefreshLobbyAsync()
    {
        try
        {
            currentGame = await Http.GetFromJsonAsync<GameRound>($"api/game/{GameCode}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LoadGameAsync Error: {ex}");
        }
    }

    private async Task OnStartGame()
    {
        var res = await Http.PostAsync($"api/game/{GameCode}/start", null);
        if (res.IsSuccessStatusCode)
        {
        }
        else
        {
            Console.WriteLine("Kunde inte starta spelet");
        }
    }

    private async Task HandleGameStartAsync()
    {
        var me = await Http.GetFromJsonAsync<Player>($"api/players/{PlayerId}");
        userRole = me?.Role.ToString() ?? "Okänd";

        showRoleModal = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(6000);
        showRoleModal = false;
        await InvokeAsync(StateHasChanged);

        NavManager.NavigateTo($"/play/{GameCode}/{PlayerId}");
    }

    public ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _cts.Dispose();
        return ValueTask.CompletedTask;
    }
}
