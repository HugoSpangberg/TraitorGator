@page "/lobby/{GameCode}/{PlayerId:guid}/{PlayerSecret}"
@rendermode InteractiveServer
@implements IAsyncDisposable

@using System.Threading
@using TraitorGator.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager NavManager

<main class="screen">
    <section class="panel panel--wide">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Lobby</p>
                <h1>Samla spelarna</h1>
            </div>
            <div class="round-pill">@((currentGame?.Players.Count ?? 0))/10</div>
        </div>

        <div class="game-code" aria-label="Spelkod">
            @foreach (var c in GameCode)
            {
                <span>@c</span>
            }
        </div>

        @if (currentGame == null)
        {
            <p class="muted">Laddar lobby...</p>
        }
        else
        {
            <div class="split">
                <section>
                    <h2>Spelare</h2>
                    <ul class="player-list">
                        @foreach (var player in currentGame.Players)
                        {
                            <li class="player-row">
                                <span>@player.Username</span>
                                @if (player.IsHost)
                                {
                                    <span class="tag">Host</span>
                                }
                            </li>
                        }
                    </ul>
                </section>

                <section class="status-box">
                    <h2>Status</h2>
                    @if (currentGame.Players.Count < currentGame.MinPlayers)
                    {
                        <p>Minst @currentGame.MinPlayers spelare behövs för att starta.</p>
                    }
                    else if (!currentGame.Started)
                    {
                        <p>Redo att starta. En spelare blir traitor när hosten startar spelet.</p>
                    }
                    else
                    {
                        <p>Spelet startar. Din roll visas om några sekunder.</p>
                    }

                    @if (!currentGame.Started)
                    {
                        @if (IsHost)
                        {
                            <button class="button button--primary button--full" disabled="@startDisabled" @onclick="OnStartGame">
                                @(isStarting ? "Startar..." : "Starta spelet")
                            </button>
                        }
                        else
                        {
                            <p class="muted">Väntar på att hosten startar.</p>
                        }
                    }
                </section>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="alert alert--error">@errorMessage</p>
        }
    </section>
</main>

@if (showRoleModal)
{
    <div class="modal-backdrop"></div>
    <section class="modal-card" role="dialog" aria-modal="true">
        <p class="eyebrow">Din roll</p>
        <h2 class="@roleClass">@roleLabel</h2>
        <p>@roleDescription</p>
    </section>
}

@code {
    [Parameter] public string GameCode { get; set; } = string.Empty;
    [Parameter] public Guid PlayerId { get; set; }
    [Parameter] public string PlayerSecret { get; set; } = string.Empty;

    private readonly CancellationTokenSource cts = new();
    private GameStateDto? currentGame;
    private string? errorMessage;
    private bool isStarting;
    private bool handledGameStart;
    private bool showRoleModal;
    private string roleLabel = "Okänd";
    private string roleDescription = string.Empty;
    private string roleClass = string.Empty;

    private bool IsHost => currentGame?.Players.Any(p => p.Id == PlayerId && p.IsHost) == true;
    private bool startDisabled => isStarting || currentGame == null || currentGame.Players.Count < currentGame.MinPlayers;

    protected override async Task OnInitializedAsync()
    {
        await RefreshLobbyAsync();
        if (currentGame?.Started == true)
        {
            _ = HandleGameStartAsync();
        }

        _ = PollLobbyAsync(cts.Token);
    }

    private async Task PollLobbyAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
                await InvokeAsync(async () =>
                {
                    await RefreshLobbyAsync();
                    if (currentGame?.Started == true && !handledGameStart)
                    {
                        _ = HandleGameStartAsync();
                    }

                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RefreshLobbyAsync()
    {
        try
        {
            currentGame = await Http.GetFromJsonAsync<GameStateDto>($"api/game/{GameCode}");
        }
        catch (HttpRequestException)
        {
            errorMessage = "Kunde inte ladda lobbyn. Kör API:t och försök igen.";
        }
    }

    private async Task OnStartGame()
    {
        if (startDisabled)
        {
            return;
        }

        isStarting = true;
        errorMessage = null;
        try
        {
            var request = new PlayerActionRequest { PlayerId = PlayerId, PlayerSecret = PlayerSecret };
            var response = await Http.PostAsJsonAsync($"api/game/{GameCode}/start", request);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await ReadErrorAsync(response, "Kunde inte starta spelet.");
                return;
            }

            currentGame = await response.Content.ReadFromJsonAsync<GameStateDto>();
            await HandleGameStartAsync();
        }
        finally
        {
            isStarting = false;
        }
    }

    private async Task HandleGameStartAsync()
    {
        if (handledGameStart)
        {
            return;
        }

        handledGameStart = true;
        var role = await LoadRoleAsync();
        roleLabel = role?.IsTraitor == true ? "TRAITOR" : "GATOR";
        roleDescription = role?.IsTraitor == true
            ? "Du får en annan fråga. Svara så trovärdigt att gruppen tvekar."
            : "Hitta spelaren vars svar inte riktigt passar frågan.";
        roleClass = role?.IsTraitor == true ? "role-traitor" : "role-gator";

        showRoleModal = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(4), cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        showRoleModal = false;
        await InvokeAsync(StateHasChanged);
        NavManager.NavigateTo($"/play/{GameCode}/{PlayerId}/{PlayerSecret}");
    }

    private async Task<PlayerRoleDto?> LoadRoleAsync()
    {
        using var request = new HttpRequestMessage(HttpMethod.Get, $"api/players/{PlayerId}/role");
        request.Headers.Add("X-Player-Secret", PlayerSecret);
        using var response = await Http.SendAsync(request);
        return response.IsSuccessStatusCode
            ? await response.Content.ReadFromJsonAsync<PlayerRoleDto>()
            : null;
    }

    private static async Task<string> ReadErrorAsync(HttpResponseMessage response, string fallback)
    {
        var body = (await response.Content.ReadAsStringAsync()).Trim().Trim('"');
        return string.IsNullOrWhiteSpace(body) ? fallback : body;
    }

    public ValueTask DisposeAsync()
    {
        cts.Cancel();
        cts.Dispose();
        return ValueTask.CompletedTask;
    }
}
