@page "/lobby/{GameCode}/{PlayerId:guid}"
@rendermode InteractiveServer
@implements IAsyncDisposable

@using System.Threading
@using TraitorGator.API.Models
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="d-flex vh-100 align-items-center justify-content-center lobby-container">
    <div class="text-center p-4 rounded-3 shadow-sm bg-dark text-light" style="max-width:500px;width:100%">

        <h1 class="mb-3">Spellobby</h1>

        <div class="mb-4">
            <h6 class="mb-4 text-primary">Game Code:</h6>
            <div class="d-flex justify-content-center code-box">
                @foreach (var c in GameCode)
                {
                    <span class="digit-box">@c</span>
                }
            </div>
        </div>

        @if (currentGame == null)
        {
            <p>Laddar lobby …</p>
        }
        else
        {
            <h5 class="mb-2">Spelare:</h5>
            <ul class="list-group mb-4">
                @foreach (var p in currentGame.Players)
                {
                    <li class="list-group-item bg-secondary bg-opacity-10 border-1">
                        @p.Username
                    </li>
                }
            </ul>

            @if (!gameStarted)
            {
                @if (IsCreator)
                {
                    <button class="btn btn-success btn-lg w-100" @onclick="OnStartGame">
                        Starta spelet
                    </button>
                }
                else
                {
                    <p class="fst-italic">Väntar på att skaparen startar spelet…</p>
                }
            }
        }

    </div>
</div>

@if (showRoleModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4 text-center">
                <h4>Din roll är:</h4>
                <p class="fs-1 text-primary">@userRole</p>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string GameCode { get; set; }
    [Parameter] public Guid PlayerId { get; set; }

    private GameRound currentGame;
    private CancellationTokenSource _cts = new();
    private bool gameStarted = false;
    private bool showRoleModal = false;
    private string userRole;

    private bool IsCreator =>
        currentGame?.Players?.FirstOrDefault()?.Id == PlayerId;

    protected override async Task OnInitializedAsync()
    {
        await RefreshLobbyAsync();

        _ = PollLobbyAsync(_cts.Token);
    }

    private async Task PollLobbyAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(5), ct);
                await RefreshLobbyAsync();

                if (!gameStarted && currentGame?.Started == true)
                {
                    gameStarted = true;
                    await InvokeAsync(HandleGameStartAsync);
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Polling Error: {ex}");
        }
    }

    private async Task RefreshLobbyAsync()
    {
        try
        {
            currentGame = await Http.GetFromJsonAsync<GameRound>($"api/game/{GameCode}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LoadGameAsync Error: {ex}");
        }
    }

    private async Task OnStartGame()
    {
        var res = await Http.PostAsync($"api/game/{GameCode}/start", null);
        if (res.IsSuccessStatusCode)
        {
        }
        else
        {
            Console.WriteLine("Kunde inte starta spelet");
        }
    }

    private async Task HandleGameStartAsync()
    {
        var me = await Http.GetFromJsonAsync<Player>($"api/players/{PlayerId}");
        userRole = me?.Role.ToString() ?? "Okänd";

        showRoleModal = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(6000);
        showRoleModal = false;
        await InvokeAsync(StateHasChanged);

        NavManager.NavigateTo($"/play/{GameCode}/{PlayerId}");
    }

    public ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _cts.Dispose();
        return ValueTask.CompletedTask;
    }
}
