@page "/results/{GameCode}/{PlayerId:guid}/{PlayerSecret}/{RoundNumber:int}"
@rendermode InteractiveServer
@implements IDisposable

@using System.Threading
@using TraitorGator.Shared.Dtos
@inject HttpClient Http
@inject NavigationManager NavManager

<main class="screen">
    <section class="panel panel--wide">
        <div class="panel-header">
            <div>
                <p class="eyebrow">Runda @RoundNumber</p>
                <h1>Jämför och rösta</h1>
            </div>
            @if (result != null)
            {
                <div class="round-pill">@result.VotesSubmitted/@result.PlayerCount röster</div>
            }
        </div>

        @if (result == null || currentGame == null)
        {
            <p class="muted">Laddar resultat...</p>
        }
        else
        {
            <div class="question-compare">
                <article>
                    <span>Gator-fråga</span>
                    <p>@result.NormalQuestion</p>
                </article>
                <article>
                    <span>Traitor-fråga</span>
                    <p>@result.TraitorQuestion</p>
                </article>
            </div>

            <section>
                <h2>Svar</h2>
                <ul class="answer-list">
                    @foreach (var answer in result.Answers)
                    {
                        <li>
                            <strong>@answer.Username</strong>
                            <span>@answer.AnswerText</span>
                        </li>
                    }
                </ul>
            </section>

            @if (!result.VotingComplete)
            {
                <section class="vote-box">
                    <h2>Vem är traitor?</h2>
                    @if (Me?.HasVoted == true)
                    {
                        <p class="muted">Din röst är inne. Väntar på resten av gruppen.</p>
                    }
                    else
                    {
                        <div class="suspect-grid">
                            @foreach (var player in currentGame.Players.Where(p => p.Id != PlayerId))
                            {
                                <button class="suspect-card @(selectedSuspectId == player.Id ? "selected" : "")"
                                        @onclick="() => selectedSuspectId = player.Id">
                                    @player.Username
                                </button>
                            }
                        </div>
                        <button class="button button--primary" disabled="@voteDisabled" @onclick="SubmitVoteAsync">
                            @(submitting ? "Röstar..." : "Lås röst")
                        </button>
                    }
                </section>
            }
            else
            {
                <section class="verdict">
                    <h2>@VerdictTitle</h2>
                    <p>@VerdictBody</p>

                    @if (result.Votes.Count > 0)
                    {
                        <ul class="vote-list">
                            @foreach (var vote in result.Votes)
                            {
                                <li><strong>@vote.VoterUsername</strong> röstade på @vote.SuspectUsername</li>
                            }
                        </ul>
                    }

                    @if (result.GameComplete)
                    {
                        <div class="status-box">
                            <h2>@(result.Winner == "Gators" ? "Gators vinner" : "Traitor vinner")</h2>
                            <p>Traitorn var @result.TraitorUsername.</p>
                        </div>
                        <button class="button button--secondary" @onclick="GoHome">Till startsidan</button>
                    }
                    else if (result.CanAdvance)
                    {
                        @if (IsHost)
                        {
                            <button class="button button--primary" disabled="@advancing" @onclick="AdvanceRoundAsync">
                                @(advancing ? "Startar..." : "Nästa runda")
                            </button>
                        }
                        else
                        {
                            <p class="muted">Väntar på att hosten startar nästa runda.</p>
                        }
                    }
                </section>
            }
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="alert alert--error">@errorMessage</p>
        }
    </section>
</main>

@code {
    [Parameter] public string GameCode { get; set; } = string.Empty;
    [Parameter] public Guid PlayerId { get; set; }
    [Parameter] public string PlayerSecret { get; set; } = string.Empty;
    [Parameter] public int RoundNumber { get; set; }

    private GameRoundResultDto? result;
    private GameStateDto? currentGame;
    private Guid? selectedSuspectId;
    private string? errorMessage;
    private bool submitting;
    private bool advancing;
    private Timer? pollTimer;

    private PlayerSummaryDto? Me => currentGame?.Players.FirstOrDefault(p => p.Id == PlayerId);
    private bool IsHost => Me?.IsHost == true;
    private bool voteDisabled => submitting || selectedSuspectId == null;
    private string VerdictTitle => result?.AccusedWasTraitor == true ? "Traitorn avslöjades" : "Fel spelare";
    private string VerdictBody => result?.AccusedWasTraitor == true
        ? $"{result.AccusedUsername} fick flest röster och var traitor."
        : $"{result?.AccusedUsername} fick flest röster, men traitorn är kvar.";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        StartPolling();
    }

    private async Task LoadAsync()
    {
        try
        {
            currentGame = await Http.GetFromJsonAsync<GameStateDto>($"api/game/{GameCode}");
            result = await Http.GetFromJsonAsync<GameRoundResultDto>($"api/gameplay/results?gameCode={GameCode}&round={RoundNumber}");
        }
        catch (HttpRequestException)
        {
            errorMessage = "Kunde inte ladda resultat. Kontrollera att API:t körs.";
        }
    }

    private async Task SubmitVoteAsync()
    {
        if (selectedSuspectId == null || submitting)
        {
            return;
        }

        submitting = true;
        errorMessage = null;
        try
        {
            var payload = new SubmitVoteRequest
            {
                VoterPlayerId = PlayerId,
                PlayerSecret = PlayerSecret,
                SuspectPlayerId = selectedSuspectId.Value,
                RoundNumber = RoundNumber
            };

            var response = await Http.PostAsJsonAsync($"api/gameplay/{GameCode}/vote", payload);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await ReadErrorAsync(response, "Kunde inte skicka rösten.");
                return;
            }

            result = await response.Content.ReadFromJsonAsync<GameRoundResultDto>();
            currentGame = await Http.GetFromJsonAsync<GameStateDto>($"api/game/{GameCode}");
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task AdvanceRoundAsync()
    {
        if (advancing)
        {
            return;
        }

        advancing = true;
        errorMessage = null;
        try
        {
            var payload = new PlayerActionRequest { PlayerId = PlayerId, PlayerSecret = PlayerSecret };
            var response = await Http.PostAsJsonAsync($"api/game/{GameCode}/next", payload);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await ReadErrorAsync(response, "Kunde inte starta nästa runda.");
                return;
            }

            NavManager.NavigateTo($"/play/{GameCode}/{PlayerId}/{PlayerSecret}");
        }
        finally
        {
            advancing = false;
        }
    }

    private void StartPolling()
    {
        pollTimer?.Dispose();
        pollTimer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 2000, 2000);
    }

    private async Task PollAsync()
    {
        await LoadAsync();
        if (currentGame?.Started == true &&
            !currentGame.IsComplete &&
            currentGame.CurrentRound > RoundNumber)
        {
            pollTimer?.Dispose();
            NavManager.NavigateTo($"/play/{GameCode}/{PlayerId}/{PlayerSecret}");
            return;
        }

        if (result?.GameComplete == true)
        {
            pollTimer?.Dispose();
            pollTimer = null;
        }

        StateHasChanged();
    }

    private static async Task<string> ReadErrorAsync(HttpResponseMessage response, string fallback)
    {
        var body = (await response.Content.ReadAsStringAsync()).Trim().Trim('"');
        return string.IsNullOrWhiteSpace(body) ? fallback : body;
    }

    private void GoHome() => NavManager.NavigateTo("/");

    public void Dispose()
    {
        pollTimer?.Dispose();
    }
}
